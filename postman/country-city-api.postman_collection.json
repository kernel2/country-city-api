  },
  "item": [
    {
      "name": "Countries",
      "item": [
        {
          "name": "Get All Countries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/countries",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "countries"
              ]
            },
            "description": "Retourne la liste de tous les pays."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"Response is an array\", function () {",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "if (body.length > 0) {",
                  "  pm.test(\"Country item has basic fields\", function () {",
                  "    pm.expect(body[0]).to.have.property('id');",
                  "    pm.expect(body[0]).to.have.property('name');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Country",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Portugal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/countries",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "countries"
              ]
            },
            "description": "Cree un nouveau pays."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"Created country has basic fields\", function () {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('name');",
                  "  pm.expect(body.name).to.eql('Portugal');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
